<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VeloTerminal.ViewModels"
             x:Class="VeloTerminal.Views.JournalView"
             x:DataType="vm:JournalViewModel">

    <Grid ColumnDefinitions="2*, 1*" Margin="16" Background="Transparent">
        
        <!-- Left: The Ledger -->
        <ExperimentalAcrylicBorder Grid.Column="0" Margin="0,0,12,0" CornerRadius="12">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="#1A1A24" TintOpacity="0.8" MaterialOpacity="0.8" />
            </ExperimentalAcrylicBorder.Material>
            
            <StackPanel Margin="20">
                <TextBlock Text="TRADE LEDGER" FontWeight="Bold" FontSize="16" Foreground="#E2E8F0" LetterSpacing="2"/>
                <Separator Margin="0,16" Background="#33FFFFFF"/>
                <DataGrid ItemsSource="{Binding Entries}" SelectedItem="{Binding SelectedEntry}" 
                          AutoGenerateColumns="False" IsReadOnly="True" GridLinesVisibility="All" 
                          Background="Transparent" RowBackground="#0AFFFFFF" Foreground="White">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Time" Binding="{Binding Order.Timestamp, StringFormat='{}{0:HH:mm:ss}'}" />
                        <DataGridTextColumn Header="Symbol" Binding="{Binding Order.Symbol}" />
                        <DataGridTextColumn Header="Qty" Binding="{Binding Order.Qty}" />
                        <DataGridTextColumn Header="Side" Binding="{Binding Order.IsBuy}" />
                        <DataGridTextColumn Header="Entry Price" Binding="{Binding Order.EntryPrice, StringFormat='{}{0:N2}'}" />
                    </DataGrid.Columns>
                </DataGrid>
            </StackPanel>
        </ExperimentalAcrylicBorder>

        <!-- Right: Reflection Zone -->
        <ExperimentalAcrylicBorder Grid.Column="1" Margin="12,0,0,0" CornerRadius="12">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="#1A1A24" TintOpacity="0.8" MaterialOpacity="0.8" />
            </ExperimentalAcrylicBorder.Material>
            
            <StackPanel Spacing="24" Margin="20" IsVisible="{Binding SelectedEntry, Converter={x:Static ObjectConverters.IsNotNull}}">
                <TextBlock Text="REFLECTION ZONE" FontWeight="Bold" FontSize="16" Foreground="#E2E8F0" LetterSpacing="2"/>
                
                <StackPanel Spacing="8">
                    <TextBlock Text="Emotional State" Foreground="#A0AEC0" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding EmotionalStates}" 
                              SelectedItem="{Binding SelectedEntry.EmotionalState}" 
                              HorizontalAlignment="Stretch"
                              Background="#111118" Foreground="White" BorderBrush="#33FFFFFF"
                              SelectionChanged="OnReflectionChanged"/>
                </StackPanel>

                <StackPanel Spacing="8">
                    <TextBlock Text="Trade Logic &amp; Notes" Foreground="#A0AEC0" FontWeight="SemiBold"/>
                    <TextBox Text="{Binding SelectedEntry.Notes, Mode=TwoWay}" 
                             AcceptsReturn="True" TextWrapping="Wrap" 
                             Height="280"
                             Background="#111118" Foreground="White" BorderBrush="#33FFFFFF" CornerRadius="6" Padding="12"
                             TextChanged="OnReflectionChanged"/>
                </StackPanel>
            </StackPanel>
        </ExperimentalAcrylicBorder>
    </Grid>
</UserControl>
