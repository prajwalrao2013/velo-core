<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VeloTerminal.ViewModels"
             x:Class="VeloTerminal.Views.ScalperView"
             x:DataType="vm:ScalperViewModel">

    <StackPanel Spacing="20">
        <TextBlock Text="SCALPER ENTRY" FontWeight="Bold" FontSize="14" Foreground="#E2E8F0" LetterSpacing="1"/>
        
        <Grid ColumnDefinitions="Auto, *">
            <TextBlock Text="Quantity:" VerticalAlignment="Center" Foreground="#A0AEC0" FontSize="15" FontWeight="SemiBold"/>
            <TextBox Grid.Column="1" Text="{Binding OrderQuantity}" Margin="12,0,0,0" 
                     VerticalAlignment="Center" FontSize="16" FontWeight="Bold"
                     Background="#111118" Foreground="White" BorderBrush="#33FFFFFF" CornerRadius="6" Padding="12,6"/>
        </Grid>

        <UniformGrid Columns="2" Height="68" Margin="0,8,0,0">
            <Button Command="{Binding BuyCommand}" Background="#10B981" Foreground="White" 
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
                    FontSize="18" FontWeight="Black" Margin="0,0,6,0" CornerRadius="8">
                BUY (F1)
            </Button>
            <Button Command="{Binding SellCommand}" Background="#EF4444" Foreground="White" 
                    HorizontalAlignment="Stretch" VerticalAlignment="Stretch" 
                    HorizontalContentAlignment="Center" VerticalContentAlignment="Center" 
                    FontSize="18" FontWeight="Black" Margin="6,0,0,0" CornerRadius="8">
                SELL (F2)
            </Button>
        </UniformGrid>

        <Border Background="#1AFFFFFF" CornerRadius="6" Padding="12">
            <TextBlock Text="{Binding RequiredMargin, StringFormat='Margin Requirement: ₹{0:N2}'}" 
                       Foreground="#CBD5E1" FontSize="13" FontWeight="SemiBold" HorizontalAlignment="Center"/>
        </Border>

        <TextBlock Text="{Binding ExecutionFeedback}" Foreground="#60A5FA" FontWeight="Bold" 
                   FontSize="14" Height="20" HorizontalAlignment="Center" LetterSpacing="1"/>
    </StackPanel>
</UserControl>
