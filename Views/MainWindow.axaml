<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VeloTerminal.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        x:Class="VeloTerminal.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="Velo Terminal"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Inter">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- ZONE 1: TOP BAR -->
        <Border DockPanel.Dock="Top" Height="48" 
                Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource PanelBorderBrush}" 
                BorderThickness="0,0,0,1"
                Padding="16,0">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <!-- Left: Logo & Psychology -->
                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock Text="VELO" FontFamily="Inter" FontWeight="Black" FontSize="18" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <Border Width="1" Height="20" Background="{StaticResource PanelBorderBrush}"/>
                    <!-- Discipline Arc / Pomodoro -->
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" DataContext="{Binding PsychologyVM}">
                        <ProgressBar Classes="Smooth" Value="{Binding PomodoroProgress}" Minimum="0" Maximum="1" Width="40" Height="4" Foreground="{StaticResource PriceUpBrush}" Background="{StaticResource Surface2Brush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PomodoroTime}" Foreground="{StaticResource PriceUpBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Center: Nav Tabs -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24" VerticalAlignment="Bottom">
                    <RadioButton Classes="NavTab" Content="TERMINAL" IsChecked="True"/>
                    <RadioButton Classes="NavTab" Content="JOURNAL"/>
                    <RadioButton Classes="NavTab" Content="ANALYTICS"/>
                    <RadioButton Classes="NavTab" Content="SETTINGS"/>
                </StackPanel>

                <!-- Right: System Info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock Text="Live · NseCM" Foreground="{StaticResource PriceUpBrush}" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock Text="14:32:05" Foreground="{StaticResource TextMutedBrush}" FontSize="11" FontWeight="Medium"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ZONE 2: LEFT DOCK -->
        <Border DockPanel.Dock="Left" Width="320" 
                Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource PanelBorderBrush}" 
                BorderThickness="0,0,1,0">
            <ScrollViewer>
                <StackPanel Spacing="16" Margin="12">
                    
                    <!-- MarketWatch -->
                    <Border Classes="SlideIn1" Background="{StaticResource Surface2Brush}" CornerRadius="{StaticResource PanelCornerRadius}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="12">
                        <StackPanel Spacing="12" DataContext="{Binding MarketWatchVM}">
                            <TextBlock Text="MARKET WATCH" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                            <ItemsControl ItemsSource="{Binding Instruments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,8">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Symbol}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Subtext}" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                <TextBlock Classes="PriceFlash" Text="{Binding Bid, StringFormat='{}{0:N2}'}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="+0.4%" FontSize="10" Foreground="{StaticResource PriceUpBrush}" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Smart Money -->
                    <Border Classes="SlideIn2" Background="{StaticResource Surface2Brush}" CornerRadius="{StaticResource PanelCornerRadius}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="12">
                        <StackPanel Spacing="12" DataContext="{Binding SmartMoneyVM}">
                            <TextBlock Text="SMART MONEY" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*">
                                <!-- Row 0 -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="FII NET" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding FiiNet}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PriceUpBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                    <TextBlock Text="DII NET" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding DiiNet}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PriceDownBrush}"/>
                                </StackPanel>
                                <!-- Row 1 -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="MAX PAIN" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding MaxPain}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                                    <TextBlock Text="PCR" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding Pcr}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Macro Calendar Expander -->
                    <Border Classes="SlideIn3" Background="{StaticResource Surface2Brush}" CornerRadius="{StaticResource PanelCornerRadius}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="12">
                        <Expander Header="MACRO CALENDAR" IsExpanded="True" DataContext="{Binding MacroCalendarVM}">
                            <ItemsControl ItemsSource="{Binding Events}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,8">
                                            <TextBlock Text="{Binding Time}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Width="40"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Impact}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentAmberBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ZONE 4: BOTTOM NEWS TICKER -->
        <Border DockPanel.Dock="Bottom" Height="32" 
                Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource PanelBorderBrush}" 
                BorderThickness="0,1,0,0">
            <ItemsControl ItemsSource="{Binding NewsTickerVM.Items}" VerticalAlignment="Center" Margin="16,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="32"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentPurpleBrush}"/>
                            <TextBlock Text="{Binding Text}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- ZONE 5: RIGHT COMMAND PANEL -->
        <Border DockPanel.Dock="Right" Width="300" 
                Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource PanelBorderBrush}" 
                BorderThickness="1,0,0,0">
            <ScrollViewer>
                <StackPanel Spacing="16" Margin="12">
                    
                    <!-- Execution Engine -->
                    <Border Classes="SlideIn4" Background="{StaticResource Surface2Brush}" CornerRadius="{StaticResource PanelCornerRadius}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="16">
                        <StackPanel Spacing="16" DataContext="{Binding ExecutionVM}">
                            <TextBlock Text="EXECUTION ENGINE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                            
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Text="{Binding Symbol}" FontSize="20" FontWeight="Black" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Classes="PriceFlash" Text="{Binding Ltp}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PriceUpBrush}" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding Change}" FontSize="11" Foreground="{StaticResource PriceUpBrush}" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>

                            <!-- Order Type Pills -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <RadioButton Classes="OrderTypePill" Content="MKT" IsChecked="True"/>
                                <RadioButton Classes="OrderTypePill" Content="LMT"/>
                                <RadioButton Classes="OrderTypePill" Content="SL"/>
                                <RadioButton Classes="OrderTypePill" Content="SL-M"/>
                            </StackPanel>

                            <!-- Inputs -->
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" Margin="0,8,0,0">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="QTY" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding Qty}" Margin="0,0,8,0"/>
                                
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="PRICE" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="0.00"/>
                            </Grid>

                            <!-- Action Buttons -->
                            <Grid ColumnDefinitions="*,*">
                                <Button Content="BUY" Background="#1A22C55E" Foreground="{StaticResource PriceUpBrush}" BorderBrush="{StaticResource PriceUpBrush}" BorderThickness="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,4,0"/>
                                <Button Grid.Column="1" Content="SELL" Background="#1AEF4444" Foreground="{StaticResource PriceDownBrush}" BorderBrush="{StaticResource PriceDownBrush}" BorderThickness="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="4,0,0,0"/>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Open Positions -->
                    <Border Classes="SlideIn4" Background="{StaticResource Surface2Brush}" CornerRadius="{StaticResource PanelCornerRadius}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="12">
                        <StackPanel Spacing="12" DataContext="{Binding PositionsVM}">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Text="OPEN POSITIONS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalPnL}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PriceUpBrush}"/>
                            </Grid>
                            
                            <ItemsControl ItemsSource="{Binding OpenPositions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*, Auto, Auto" Margin="0,0,0,8">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding Symbol}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Type}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentAmberBrush}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Entry, StringFormat='{}Avg {0}'}" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            </StackPanel>
                                            <TextBlock Classes="PriceFlash" Grid.Column="1" Text="{Binding Ltp}" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="8,0"/>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding PnlAmount}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource PriceUpBrush}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding PnlPct}" FontSize="10" Foreground="{StaticResource PriceUpBrush}" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    
                    <!-- Psychology Engine / Habits -->
                    <Border Classes="SlideIn4" Background="{StaticResource Surface2Brush}" CornerRadius="{StaticResource PanelCornerRadius}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="12">
                        <StackPanel Spacing="12" DataContext="{Binding PsychologyVM}">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Text="PSYCHOLOGY" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding StreakDays}" FontSize="11" Foreground="{StaticResource AccentAmberBrush}"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Habits}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Text}" IsChecked="{Binding IsChecked}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ZONE 3: CENTER CHART -->
        <Border Background="{StaticResource BackgroundBrush}" Margin="16" DataContext="{Binding ChartVM}">
            <Grid RowDefinitions="Auto, *">
                
                <!-- Chart Toolbar -->
                <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,0,16,16">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="{Binding SelectedSymbol}" FontSize="24" FontWeight="Black" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="+124.50 (0.42%)" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PriceUpBrush}" VerticalAlignment="Center"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                        <RadioButton Classes="TimeframePill" Content="1m"/>
                        <RadioButton Classes="TimeframePill" Content="5m" IsChecked="True"/>
                        <RadioButton Classes="TimeframePill" Content="15m"/>
                        <RadioButton Classes="TimeframePill" Content="1h"/>
                        <RadioButton Classes="TimeframePill" Content="D"/>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                        <Button Classes="Flat" Content="Indicators"/>
                        <Button Classes="Flat" Content="Ghost Mode"/>
                    </StackPanel>
                </Grid>

                <!-- LiveCharts2 Canvas -->
                <lvc:CartesianChart Grid.Row="1" Series="{Binding Series}" AnimationsSpeed="00:00:00.150"/>
            </Grid>
        </Border>
    </DockPanel>
</Window>
