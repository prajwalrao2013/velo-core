<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VeloTerminal.ViewModels"
        xmlns:views="using:VeloTerminal.Views"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="VeloTerminal.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Velo Terminal"
        Background="Transparent"
        TransparencyLevelHint="AcrylicBlur"
        ExtendClientAreaToDecorationsHint="True"
        WindowStartupLocation="CenterScreen">

    <Window.KeyBindings>
        <KeyBinding Gesture="F1" Command="{Binding ScalperVM.BuyCommand}" />
        <KeyBinding Gesture="F2" Command="{Binding ScalperVM.SellCommand}" />
    </Window.KeyBindings>

    <Panel>
        <ExperimentalAcrylicBorder IsHitTestVisible="False">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="#0a0a0f" TintOpacity="0.9" MaterialOpacity="0.6" />
            </ExperimentalAcrylicBorder.Material>
        </ExperimentalAcrylicBorder>

        <DockPanel Margin="0,35,0,0">
            <!-- Global Navigation Bar -->
            <Border DockPanel.Dock="Top" Background="#1AFFFFFF" Padding="20,12" BorderBrush="#33FFFFFF" BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*, Auto">
                    <StackPanel Orientation="Horizontal" Spacing="12">
                        <TextBlock Text="VELO" FontWeight="Black" Foreground="White" FontSize="20" VerticalAlignment="Center" LetterSpacing="2"/>
                        <Border Background="#6366F1" CornerRadius="4" Padding="6,2">
                            <TextBlock Text="PRO" FontWeight="Bold" Foreground="White" FontSize="11" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                    
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                        <TextBlock Text="Discipline Score:" Foreground="#A0AEC0" VerticalAlignment="Center" FontSize="14" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding DisciplineScore}" FontWeight="Bold" FontSize="18" Foreground="#10B981" VerticalAlignment="Center"/>
                        <Border Background="#EF4444" CornerRadius="4" Padding="6,2" IsVisible="{Binding IsScoreCritical}" Margin="8,0,0,0">
                            <TextBlock Text="CRITICAL TILT" Foreground="White" FontWeight="Bold" FontSize="11" VerticalAlignment="Center"/>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <TabControl Background="Transparent" Margin="0,10,0,0">
                <!-- Apply modern padding to tabs but leave default logic active -->
                <TabItem Header="TERMINAL" FontSize="14" FontWeight="SemiBold">
                    <Grid ColumnDefinitions="320, *, 340" RowDefinitions="*, Auto" Margin="12,12,12,0">
                        
                        <!-- Left: Marketwatch -->
                        <ExperimentalAcrylicBorder Grid.Column="0" Margin="8" CornerRadius="12">
                            <ExperimentalAcrylicBorder.Material>
                                <ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="#1A1A24" TintOpacity="0.8" MaterialOpacity="0.8" />
                            </ExperimentalAcrylicBorder.Material>
                            <StackPanel Margin="16">
                                <TextBlock Text="MARKETWATCH" FontWeight="Bold" FontSize="14" Foreground="#E2E8F0" LetterSpacing="1"/>
                                <Separator Margin="0,12" Background="#33FFFFFF"/>
                                
                                <Grid ColumnDefinitions="*,*,*">
                                    <TextBlock Text="SYMBOL" Foreground="#718096" FontSize="11" FontWeight="Bold"/>
                                    <TextBlock Grid.Column="1" Text="BID" Foreground="#718096" FontSize="11" FontWeight="Bold" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="ASK" Foreground="#718096" FontSize="11" FontWeight="Bold" TextAlignment="Right"/>
                                </Grid>
                                <Grid ColumnDefinitions="*,*,*" Margin="0,12,0,0">
                                    <TextBlock Text="{Binding LatestTick.Symbol}" FontWeight="Bold" Foreground="White" FontSize="15"/>
                                    <TextBlock Grid.Column="1" Text="{Binding LatestTick.Bid}" Foreground="#F87171" FontWeight="SemiBold" FontSize="15" TextAlignment="Right"/>
                                    <TextBlock Grid.Column="2" Text="{Binding LatestTick.Ask}" Foreground="#34D399" FontWeight="SemiBold" FontSize="15" TextAlignment="Right"/>
                                </Grid>
                            </StackPanel>
                        </ExperimentalAcrylicBorder>

                        <!-- Center: Chart & Positions -->
                        <Grid Grid.Column="1" RowDefinitions="3*, 1*" Margin="0,8">
                            <ExperimentalAcrylicBorder CornerRadius="12">
                                <ExperimentalAcrylicBorder.Material>
                                    <ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="#1A1A24" TintOpacity="0.8" MaterialOpacity="0.8" />
                                </ExperimentalAcrylicBorder.Material>
                                <!-- LiveCharts Area -->
                                <lvc:CartesianChart Series="{Binding ChartSeries}" Sections="{Binding Sections}" Margin="12"/>
                            </ExperimentalAcrylicBorder>

                            <ExperimentalAcrylicBorder Grid.Row="1" Margin="0,16,0,0" CornerRadius="12">
                                <ExperimentalAcrylicBorder.Material>
                                    <ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="#1A1A24" TintOpacity="0.8" MaterialOpacity="0.8" />
                                </ExperimentalAcrylicBorder.Material>
                                <TextBlock Text="ACTIVE POSITIONS" Foreground="#4A5568" FontWeight="Bold" LetterSpacing="2" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </ExperimentalAcrylicBorder>
                        </Grid>

                        <!-- Right: Execution & Psychology -->
                        <ExperimentalAcrylicBorder Grid.Column="2" Margin="8" CornerRadius="12">
                            <ExperimentalAcrylicBorder.Material>
                                <ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="#1A1A24" TintOpacity="0.8" MaterialOpacity="0.8" />
                            </ExperimentalAcrylicBorder.Material>
                            
                            <StackPanel Spacing="24" Margin="16">
                                <!-- Isolated Custom UI -->
                                <views:ScalperView DataContext="{Binding ScalperVM}" />

                                <Separator Background="#33FFFFFF"/>

                                <!-- Psychology Panel -->
                                <StackPanel Spacing="12">
                                    <TextBlock Text="PSYCHOLOGY ENGINE" FontWeight="Bold" FontSize="14" Foreground="#E2E8F0" LetterSpacing="1"/>
                                    
                                    <Border Background="#33F59E0B" CornerRadius="8" Padding="12" IsVisible="{Binding IsTiltWarningActive}" BorderBrush="#F59E0B" BorderThickness="1">
                                        <TextBlock Text="{Binding TiltWarningText}" Foreground="#FCD34D" FontSize="13" TextWrapping="Wrap"/>
                                    </Border>
                                    
                                    <Grid ColumnDefinitions="*, Auto" Margin="0,8,0,0">
                                        <TextBlock Text="Pomodoro Focus:" VerticalAlignment="Center" Foreground="#A0AEC0" FontSize="14"/>
                                        <Border Grid.Column="1" Background="#336366F1" CornerRadius="6" Padding="8,4">
                                            <TextBlock Text="{Binding PomodoroText}" FontSize="18" FontWeight="Bold" Foreground="#818CF8" HorizontalAlignment="Right"/>
                                        </Border>
                                    </Grid>
                                </StackPanel>
                            </StackPanel>
                        </ExperimentalAcrylicBorder>

                        <!-- Bottom: Ticker -->
                        <Border Grid.Row="1" Grid.ColumnSpan="3" Background="#0A0A0F" Padding="16,8" Margin="8,16,8,8" CornerRadius="8">
                            <ItemsControl ItemsSource="{Binding Events}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="24"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="⚡" Foreground="#F59E0B" VerticalAlignment="Center" FontSize="12"/>
                                            <TextBlock Text="{Binding Headline}" Foreground="#E2E8F0" FontSize="13" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Border>
                    </Grid>
                </TabItem>
                
                <TabItem Header="JOURNAL" FontSize="14" FontWeight="SemiBold">
                    <views:JournalView DataContext="{Binding JournalVM}" />
                </TabItem>

                <TabItem Header="ANALYTICS" FontSize="14" FontWeight="SemiBold">
                    <views:AnalyticsView DataContext="{Binding AnalyticsVM}" />
                </TabItem>
                
            </TabControl>
        </DockPanel>
    </Panel>
</Window>
