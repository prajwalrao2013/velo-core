<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VeloTerminal.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
        mc:Ignorable="d" d:DesignWidth="1920" d:DesignHeight="1080"
        x:Class="VeloTerminal.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Title="Velo Terminal"
        Background="{StaticResource BackgroundBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        FontFamily="Inter">

    <Design.DataContext>
        <vm:MainViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- ZONE 1: TOP BAR -->
        <Border DockPanel.Dock="Top" Height="48" 
                Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource PanelBorderBrush}" 
                BorderThickness="0,0,0,1"
                Padding="16,0">
            <Grid ColumnDefinitions="Auto, *, Auto">
                <!-- Left: Logo & Psychology -->
                <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock Text="VELO" FontFamily="Inter" FontWeight="Black" FontSize="18" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <Border Width="1" Height="20" Background="{StaticResource PanelBorderBrush}"/>
                    <!-- Discipline Arc / Pomodoro -->
                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" DataContext="{Binding PsychologyVM}">
                        <ProgressBar Classes="Smooth" Value="{Binding PomodoroProgress}" Minimum="0" Maximum="1" Width="40" Height="4" Foreground="{StaticResource PriceUpBrush}" Background="{StaticResource Surface2Brush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding PomodoroTime}" Foreground="{StaticResource PriceUpBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>

                <!-- Center: Nav Tabs -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24" VerticalAlignment="Bottom">
                    <RadioButton Classes="NavTab" Content="TERMINAL" IsChecked="True" Command="{Binding SwitchWorkspaceCommand}" CommandParameter="TERMINAL"/>
                    <RadioButton Classes="NavTab" Content="ARENA" Command="{Binding SwitchWorkspaceCommand}" CommandParameter="ARENA"/>
                    <RadioButton Classes="NavTab" Content="PULSE" Command="{Binding SwitchWorkspaceCommand}" CommandParameter="PULSE"/>
                    <RadioButton Classes="NavTab" Content="JOURNAL" Command="{Binding SwitchWorkspaceCommand}" CommandParameter="JOURNAL"/>
                </StackPanel>

                <!-- Right: System Info -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
                    <TextBlock Text="Live · NseCM" Foreground="{StaticResource PriceUpBrush}" FontSize="11" FontWeight="SemiBold"/>
                    <TextBlock Text="14:32:05" Foreground="{StaticResource TextMutedBrush}" FontSize="11" FontWeight="Medium"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ZONE 2: LEFT DOCK -->
        <Border DockPanel.Dock="Left" Width="320" 
                Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource PanelBorderBrush}" 
                BorderThickness="0,0,1,0">
            <ScrollViewer>
                <StackPanel Spacing="16" Margin="12">
                    
                    <!-- MarketWatch -->
                    <Border Classes="SlideIn1" Background="{StaticResource Surface2Brush}" CornerRadius="{StaticResource PanelCornerRadius}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="12">
                        <StackPanel Spacing="12" DataContext="{Binding MarketWatchVM}">
                            <TextBlock Text="MARKET WATCH" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                            <ItemsControl ItemsSource="{Binding Instruments}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Background="Transparent">
                                            <StackPanel>
                                                <Grid ColumnDefinitions="*, Auto" Margin="0,0,0,8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Symbol}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding Subtext}" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                                    </StackPanel>
                                                    <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                                        <TextBlock Classes="PriceFlash" Text="{Binding Bid, StringFormat='{}{0:N2}'}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Right"/>
                                                        <TextBlock Text="+0.4%" FontSize="10" Foreground="{StaticResource PriceUpBrush}" HorizontalAlignment="Right"/>
                                                    </StackPanel>
                                                </Grid>
                                                
                                                <!-- Phase 3: Hover 52W State -->
                                                <Border Classes="HoverDetails" Height="0" Opacity="0" ClipToBounds="True">
                                                    <StackPanel Margin="0,0,0,8">
                                                        <Grid ColumnDefinitions="Auto, *, Auto">
                                                            <TextBlock Text="{Binding Low52}" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                                            <TextBlock Grid.Column="1" Text="52W RANGE" FontSize="9" HorizontalAlignment="Center" Foreground="{StaticResource TextMutedBrush}"/>
                                                            <TextBlock Grid.Column="2" Text="{Binding High52}" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                                        </Grid>
                                                        <ProgressBar Minimum="{Binding Low52}" Maximum="{Binding High52}" Value="{Binding Bid}" Height="4" Background="{StaticResource Surface3Brush}" Foreground="{StaticResource AccentPurpleBrush}" Margin="0,4,0,0" CornerRadius="2"/>
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Smart Money -->
                    <Border Classes="SlideIn2" Background="{StaticResource Surface2Brush}" CornerRadius="{StaticResource PanelCornerRadius}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="12">
                        <StackPanel Spacing="12" DataContext="{Binding SmartMoneyVM}">
                            <TextBlock Text="SMART MONEY" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                            <Grid RowDefinitions="Auto,Auto,Auto" ColumnDefinitions="*,*">
                                <!-- Row 0 -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="FII NET" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding FiiNet}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PriceUpBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,0,8">
                                    <TextBlock Text="DII NET" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding DiiNet}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PriceDownBrush}"/>
                                </StackPanel>
                                <!-- Row 1 -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,8">
                                    <TextBlock Text="MAX PAIN" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding MaxPain}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                                <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,0,8">
                                    <TextBlock Text="PCR" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Text="{Binding Pcr}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                </StackPanel>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Macro Calendar Expander -->
                    <Border Classes="SlideIn3" Background="{StaticResource Surface2Brush}" CornerRadius="{StaticResource PanelCornerRadius}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="12">
                        <Expander Header="MACRO CALENDAR" IsExpanded="True" DataContext="{Binding MacroCalendarVM}">
                            <ItemsControl ItemsSource="{Binding Events}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,0,0,8">
                                            <TextBlock Text="{Binding Time}" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Width="40"/>
                                            <TextBlock Grid.Column="1" Text="{Binding Name}" FontSize="12" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}"/>
                                            <TextBlock Grid.Column="2" Text="{Binding Impact}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentAmberBrush}"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ZONE 4: BOTTOM NEWS TICKER -->
        <Border DockPanel.Dock="Bottom" Height="32" 
                Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource PanelBorderBrush}" 
                BorderThickness="0,1,0,0">
            <ItemsControl ItemsSource="{Binding NewsTickerVM.Items}" VerticalAlignment="Center" Margin="16,0">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="32"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="{Binding Category}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentPurpleBrush}"/>
                            <TextBlock Text="{Binding Text}" FontSize="11" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </Border>

        <!-- ZONE 5: RIGHT COMMAND PANEL -->
        <Border DockPanel.Dock="Right" Width="300" 
                Background="{StaticResource SurfaceBrush}" 
                BorderBrush="{StaticResource PanelBorderBrush}" 
                BorderThickness="1,0,0,0">
            <ScrollViewer>
                <StackPanel Spacing="16" Margin="12">
                    
                    <!-- Execution Engine -->
                    <Border Classes="SlideIn4" Background="{StaticResource Surface2Brush}" CornerRadius="{StaticResource PanelCornerRadius}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="16">
                        <StackPanel Spacing="16" DataContext="{Binding ExecutionVM}">
                            <TextBlock Text="EXECUTION ENGINE" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                            
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Text="{Binding Symbol}" FontSize="20" FontWeight="Black" Foreground="{StaticResource TextPrimaryBrush}"/>
                                <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                    <TextBlock Classes="PriceFlash" Text="{Binding Ltp}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PriceUpBrush}" HorizontalAlignment="Right"/>
                                    <TextBlock Text="{Binding Change}" FontSize="11" Foreground="{StaticResource PriceUpBrush}" HorizontalAlignment="Right"/>
                                </StackPanel>
                            </Grid>

                            <!-- Order Type Pills -->
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <RadioButton Classes="OrderTypePill" Content="MKT" IsChecked="{Binding IsMkt}"/>
                                <RadioButton Classes="OrderTypePill" Content="LMT" IsChecked="{Binding IsLmt}"/>
                                <RadioButton Classes="OrderTypePill" Content="SL" IsChecked="{Binding IsSl}"/>
                                <RadioButton Classes="OrderTypePill" Content="SL-M" IsChecked="{Binding IsSlm}"/>
                            </StackPanel>

                            <!-- Inputs -->
                            <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="*,*" Margin="0,8,0,0">
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="QTY" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBox Grid.Row="1" Grid.Column="0" Text="{Binding Qty}" Margin="0,0,8,0"/>
                                
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="PRICE" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBox Grid.Row="1" Grid.Column="1" Text="0.00"/>
                            </Grid>

                            <!-- RR Visual Bar -->
                            <StackPanel Spacing="4" Margin="0,8,0,0">
                                <Grid ColumnDefinitions="*,*">
                                    <TextBlock Text="RISK" FontSize="9" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBlock Grid.Column="1" Text="REWARD" FontSize="9" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Right"/>
                                </Grid>
                                <Grid Height="4" Margin="0,2,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="{Binding RiskWidth, StringFormat='{}{0}*'}"/>
                                        <ColumnDefinition Width="{Binding RewardWidth, StringFormat='{}{0}*'}"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Background="{StaticResource PriceDownBrush}" CornerRadius="2,0,0,2"/>
                                    <Border Grid.Column="1" Background="{StaticResource PriceUpBrush}" CornerRadius="0,2,2,0"/>
                                </Grid>
                            </StackPanel>

                            <!-- Action Buttons -->
                            <Grid Margin="0,8,0,0">
                                <Grid ColumnDefinitions="*,*">
                                    <Button Content="BUY" Command="{Binding ExecuteTradeCommand}" CommandParameter="BUY" Background="#1A22C55E" Foreground="{StaticResource PriceUpBrush}" BorderBrush="{StaticResource PriceUpBrush}" BorderThickness="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="0,0,4,0"/>
                                    <Button Grid.Column="1" Content="SELL" Command="{Binding ExecuteTradeCommand}" CommandParameter="SELL" Background="#1AEF4444" Foreground="{StaticResource PriceDownBrush}" BorderBrush="{StaticResource PriceDownBrush}" BorderThickness="1" HorizontalAlignment="Stretch" HorizontalContentAlignment="Center" Margin="4,0,0,0"/>
                                </Grid>
                                <!-- Pre-Trade Gate -->
                                <Border Background="{StaticResource Surface3Brush}" CornerRadius="{StaticResource PanelCornerRadius}" IsVisible="{Binding IsTradeGateActive}" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
                                    <TextBlock Text="{Binding GateMessage}" Foreground="{StaticResource AccentAmberBrush}" FontSize="10" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Open Positions -->
                    <Border Classes="SlideIn4" Background="{StaticResource Surface2Brush}" CornerRadius="{StaticResource PanelCornerRadius}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="12">
                        <StackPanel Spacing="12" DataContext="{Binding PositionsVM}">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Text="OPEN POSITIONS" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding TotalPnL}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PriceUpBrush}"/>
                            </Grid>
                            
                            <ItemsControl ItemsSource="{Binding OpenPositions}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid ColumnDefinitions="*, Auto, Auto" Margin="0,0,0,8">
                                            <StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="4">
                                                    <TextBlock Text="{Binding Symbol}" FontSize="13" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                    <TextBlock Text="{Binding Type}" FontSize="10" FontWeight="Bold" Foreground="{StaticResource AccentAmberBrush}"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Entry, StringFormat='{}Avg {0}'}" FontSize="10" Foreground="{StaticResource TextMutedBrush}"/>
                                            </StackPanel>
                                            <TextBlock Classes="PriceFlash" Grid.Column="1" Text="{Binding Ltp}" FontSize="13" FontWeight="Medium" Foreground="{StaticResource TextPrimaryBrush}" Margin="8,0"/>
                                            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding PnlAmount}" FontSize="13" FontWeight="Bold" Foreground="{StaticResource PriceUpBrush}" HorizontalAlignment="Right"/>
                                                <TextBlock Text="{Binding PnlPct}" FontSize="10" Foreground="{StaticResource PriceUpBrush}" HorizontalAlignment="Right"/>
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                    
                    <!-- Psychology Engine / Habits -->
                    <Border Classes="SlideIn4" Background="{StaticResource Surface2Brush}" CornerRadius="{StaticResource PanelCornerRadius}" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="12">
                        <StackPanel Spacing="12" DataContext="{Binding PsychologyVM}">
                            <Grid ColumnDefinitions="*, Auto">
                                <TextBlock Text="PSYCHOLOGY" FontSize="11" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Grid.Column="1" Text="{Binding StreakDays}" FontSize="11" Foreground="{StaticResource AccentAmberBrush}"/>
                            </Grid>
                            <ItemsControl ItemsSource="{Binding Habits}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <CheckBox Content="{Binding Text}" IsChecked="{Binding IsChecked}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="12" Margin="0,0,0,4"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <!-- ZONE 3: CENTER CHART / WORKSPACE SWAPPER -->
        <Border Background="{StaticResource BackgroundBrush}" Margin="16">
            <TransitioningContentControl Content="{Binding CurrentWorkspaceView}">
                <TransitioningContentControl.DataTemplates>
                    <!-- TERMINAL CHART -->
                    <DataTemplate DataType="{x:Type vm:ChartViewModel}">
                        <Grid RowDefinitions="Auto, *, 80">
                            <!-- Chart Toolbar -->
                            <Grid ColumnDefinitions="Auto, *, Auto" Margin="0,0,16,16">
                                <StackPanel Orientation="Horizontal" Spacing="12">
                                    <TextBlock Text="{Binding SelectedSymbol}" FontSize="24" FontWeight="Black" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="+124.50 (0.42%)" FontSize="14" FontWeight="SemiBold" Foreground="{StaticResource PriceUpBrush}" VerticalAlignment="Center"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="4">
                                    <RadioButton Classes="TimeframePill" Content="1m" Command="{Binding ChangeTimeframeCommand}" CommandParameter="1m"/>
                                    <RadioButton Classes="TimeframePill" Content="5m" IsChecked="True" Command="{Binding ChangeTimeframeCommand}" CommandParameter="5m"/>
                                    <RadioButton Classes="TimeframePill" Content="15m" Command="{Binding ChangeTimeframeCommand}" CommandParameter="15m"/>
                                    <RadioButton Classes="TimeframePill" Content="1h" Command="{Binding ChangeTimeframeCommand}" CommandParameter="1h"/>
                                    <RadioButton Classes="TimeframePill" Content="D" Command="{Binding ChangeTimeframeCommand}" CommandParameter="D"/>
                                </StackPanel>
                                
                                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                                    <Button Classes="Flat" Content="Indicators"/>
                                    <ToggleButton Classes="GhostToggle" Content="Ghost Mode" IsChecked="{Binding GhostModeOn}"/>
                                </StackPanel>
                            </Grid>

                            <!-- LiveCharts2 Canvas Main -->
                            <lvc:CartesianChart Grid.Row="1" Series="{Binding Series}" XAxes="{Binding XAxes}" YAxes="{Binding YAxes}" AnimationsSpeed="00:00:00.050"/>
                            
                            <!-- LiveCharts2 Canvas Volume -->
                            <lvc:CartesianChart Grid.Row="2" Series="{Binding VolumeSeries}" XAxes="{Binding VolumeXAxes}" YAxes="{Binding VolumeYAxes}" AnimationsSpeed="00:00:00.050" TooltipPosition="Hidden"/>
                        </Grid>
                    </DataTemplate>

                    <!-- ARENA IDEA BOARD -->
                    <DataTemplate DataType="{x:Type vm:ArenaWorkspaceViewModel}">
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding Ideas}" Margin="32">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="16"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Surface2Brush}" CornerRadius="8" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="16">
                                            <StackPanel Spacing="8">
                                                <Grid ColumnDefinitions="*, Auto">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding User}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding Tag}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentPurpleBrush}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding Pnl}" FontSize="12" FontWeight="Bold" Foreground="{StaticResource PriceUpBrush}"/>
                                                </Grid>
                                                <TextBlock Text="{Binding Body}" FontSize="14" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DataTemplate>

                    <!-- PULSE GLOBAL MATRIX -->
                    <DataTemplate DataType="{x:Type vm:PulseWorkspaceViewModel}">
                        <Grid RowDefinitions="Auto, *">
                            <!-- Fear & Greed Arc -->
                            <Border Grid.Row="0" Margin="32" Background="{StaticResource Surface2Brush}" CornerRadius="8" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="24" HorizontalAlignment="Center">
                                <StackPanel Spacing="16" HorizontalAlignment="Center">
                                    <TextBlock Text="FEAR &amp; GREED INDEX" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center"/>
                                    <Grid Width="200" Height="100">
                                        <!-- Basic Arc Implementation -->
                                        <Path Data="M 0,100 A 100,100 0 0,1 200,100" Stroke="{StaticResource Surface3Brush}" StrokeThickness="16" Stretch="None"/>
                                        <Path Data="M 0,100 A 100,100 0 0,1 160,20" Stroke="{StaticResource PriceUpBrush}" StrokeThickness="16" Stretch="None"/>
                                        <TextBlock Text="62" FontSize="48" FontWeight="Black" Foreground="{StaticResource PriceUpBrush}" HorizontalAlignment="Center" VerticalAlignment="Bottom"/>
                                    </Grid>
                                    <TextBlock Text="GREED" FontSize="16" FontWeight="Black" Foreground="{StaticResource PriceUpBrush}" HorizontalAlignment="Center"/>
                                </StackPanel>
                            </Border>
                            
                            <!-- Global Assets UniformGrid -->
                            <ItemsControl Grid.Row="1" ItemsSource="{Binding Assets}" Margin="32">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <UniformGrid Columns="3"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Surface2Brush}" CornerRadius="8" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="16" Margin="8">
                                            <StackPanel Spacing="8" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" FontSize="14" FontWeight="Bold" Foreground="{StaticResource TextMutedBrush}"/>
                                                <TextBlock Text="{Binding Value}" FontSize="24" FontWeight="Black" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding Change}" FontSize="14" FontWeight="Bold">
                                                    <TextBlock.Foreground>
                                                        <SolidColorBrush Color="{Binding ColorHex}"/>
                                                    </TextBlock.Foreground>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Grid>
                    </DataTemplate>

                    <!-- JOURNAL -->
                    <DataTemplate DataType="{x:Type vm:JournalWorkspaceViewModel}">
                        <ScrollViewer>
                            <ItemsControl ItemsSource="{Binding Entries}" Margin="32">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Spacing="16"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{StaticResource Surface2Brush}" CornerRadius="8" BorderBrush="{StaticResource PanelBorderBrush}" BorderThickness="1" Padding="16">
                                            <StackPanel Spacing="8">
                                                <Grid ColumnDefinitions="*, Auto">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="{Binding Order.Symbol}" FontSize="16" FontWeight="Bold" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        <TextBlock Text="{Binding Order.IsBuy}" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource AccentPurpleBrush}" VerticalAlignment="Center"/>
                                                    </StackPanel>
                                                    <TextBlock Grid.Column="1" Text="{Binding Order.Timestamp, StringFormat='{}{0:HH:mm:ss}'}" FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                                                </Grid>
                                                <TextBlock Text="{Binding Notes}" FontSize="14" Foreground="{StaticResource TextPrimaryBrush}"/>
                                                <TextBlock Text="{Binding EmotionalState}" FontSize="12" Foreground="{StaticResource AccentAmberBrush}"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </DataTemplate>
                </TransitioningContentControl.DataTemplates>
            </TransitioningContentControl>
        </Border>
    </DockPanel>
</Window>
