<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:VeloTerminal.ViewModels"
             xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia"
             x:Class="VeloTerminal.Views.AnalyticsView"
             x:DataType="vm:AnalyticsViewModel">

    <Grid RowDefinitions="Auto, *" Margin="16" Background="Transparent">
        
        <!-- Top Row: KPI Cards -->
        <UniformGrid Columns="3" Height="120" Margin="0,0,0,16">
            
            <ExperimentalAcrylicBorder Margin="0,0,8,0" CornerRadius="12">
                <ExperimentalAcrylicBorder.Material>
                    <ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="#1A1A24" TintOpacity="0.8" MaterialOpacity="0.8" />
                </ExperimentalAcrylicBorder.Material>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="MOCK WIN RATE" Foreground="#A0AEC0" FontSize="13" FontWeight="Bold" LetterSpacing="1" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding WinRate}" FontWeight="Black" FontSize="36" Foreground="#10B981" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </ExperimentalAcrylicBorder>

            <ExperimentalAcrylicBorder Margin="4,0,4,0" CornerRadius="12">
                <ExperimentalAcrylicBorder.Material>
                    <ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="#1A1A24" TintOpacity="0.8" MaterialOpacity="0.8" />
                </ExperimentalAcrylicBorder.Material>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="PROFIT FACTOR" Foreground="#A0AEC0" FontSize="13" FontWeight="Bold" LetterSpacing="1" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding ProfitFactor}" FontWeight="Black" FontSize="36" Foreground="#3B82F6" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </ExperimentalAcrylicBorder>

            <ExperimentalAcrylicBorder Margin="8,0,0,0" CornerRadius="12">
                <ExperimentalAcrylicBorder.Material>
                    <ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="#1A1A24" TintOpacity="0.8" MaterialOpacity="0.8" />
                </ExperimentalAcrylicBorder.Material>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock Text="EXTRAPOLATED P&amp;L" Foreground="#A0AEC0" FontSize="13" FontWeight="Bold" LetterSpacing="1" HorizontalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalPnL}" FontWeight="Black" FontSize="36" Foreground="#F59E0B" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>
            </ExperimentalAcrylicBorder>
        </UniformGrid>

        <!-- Bottom Row: Emotional Heatmap Chart -->
        <ExperimentalAcrylicBorder Grid.Row="1" CornerRadius="12">
            <ExperimentalAcrylicBorder.Material>
                <ExperimentalAcrylicMaterial BackgroundSource="Digger" TintColor="#1A1A24" TintOpacity="0.8" MaterialOpacity="0.8" />
            </ExperimentalAcrylicBorder.Material>
            <StackPanel Margin="20">
                <TextBlock Text="EMOTIONAL P&amp;L HEATMAP" FontWeight="Bold" FontSize="16" Foreground="#E2E8F0" LetterSpacing="2" Margin="0,0,0,16"/>
                <!-- Chart bounds mapping ColumnSeries natively -->
                <lvc:CartesianChart Series="{Binding EmotionSeries}" XAxes="{Binding XAxes}" Height="400"/>
            </StackPanel>
        </ExperimentalAcrylicBorder>

    </Grid>
</UserControl>
