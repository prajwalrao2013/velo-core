<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">
    
    <!-- Colors -->
    <Color x:Key="BackgroundColor">#050505</Color>
    <Color x:Key="SurfaceColor">#0D0D0F</Color>
    <Color x:Key="Surface2Color">#111113</Color>
    <Color x:Key="PanelBorderColor">#27272A</Color>
    
    <Color x:Key="TextPrimaryColor">#E4E4E7</Color>
    <Color x:Key="TextMutedColor">#71717A</Color>
    <Color x:Key="TextFaintColor">#3F3F46</Color>
    
    <Color x:Key="PriceUpColor">#22C55E</Color>
    <Color x:Key="PriceDownColor">#EF4444</Color>
    
    <Color x:Key="AccentPurpleColor">#A855F7</Color>
    <Color x:Key="AccentAmberColor">#F59E0B</Color>
    
    <Color x:Key="MA20Color">#F59E0B</Color>
    <Color x:Key="MA50Color">#3B82F6</Color>
    <Color x:Key="VWAPColor">#8B5CF6</Color>

    <!-- Brushes -->
    <SolidColorBrush x:Key="BackgroundBrush" Color="{StaticResource BackgroundColor}"/>
    <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}"/>
    <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2Color}"/>
    <SolidColorBrush x:Key="PanelBorderBrush" Color="{StaticResource PanelBorderColor}"/>
    
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimaryColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="TextFaintBrush" Color="{StaticResource TextFaintColor}"/>
    
    <SolidColorBrush x:Key="PriceUpBrush" Color="{StaticResource PriceUpColor}"/>
    <SolidColorBrush x:Key="PriceDownBrush" Color="{StaticResource PriceDownColor}"/>
    
    <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurpleColor}"/>
    <SolidColorBrush x:Key="AccentAmberBrush" Color="{StaticResource AccentAmberColor}"/>

    <!-- Layout Constants -->
    <CornerRadius x:Key="PanelCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="RowCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="PillCornerRadius">9999</CornerRadius>
    
    <Thickness x:Key="PanelBorderThickness">1</Thickness>
    
    <!-- Animations / Timings -->
    <sys:TimeSpan x:Key="FastTransition">0:0:0.150</sys:TimeSpan>
    <sys:TimeSpan x:Key="SlowTransition">0:0:0.300</sys:TimeSpan>

    <!-- DropShadows / BoxShadows -->
    <BoxShadows x:Key="PanelShadow">0 10 24 0 #80000000</BoxShadows>
    <BoxShadows x:Key="PriceUpGlow">0 0 8 0 #8022C55E</BoxShadows>
    <BoxShadows x:Key="PriceDownGlow">0 0 8 0 #80EF4444</BoxShadows>
    <BoxShadows x:Key="ActivePillGlow">0 0 12 0 #6622C55E</BoxShadows>

</ResourceDictionary>
