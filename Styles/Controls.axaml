<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
        
    <!-- Custom ScrollBar -->
    <Style Selector="ScrollBar">
        <Setter Property="AllowAutoHide" Value="False"/>
        <Setter Property="Width" Value="4"/>
        <Setter Property="Background" Value="Transparent"/>
    </Style>
    <Style Selector="ScrollBar /template/ Thumb">
        <Setter Property="Background" Value="{StaticResource PanelBorderBrush}"/>
        <Setter Property="CornerRadius" Value="2"/>
    </Style>
    <Style Selector="ScrollBar /template/ RepeatButton">
        <Setter Property="IsVisible" Value="False"/>
    </Style>

    <!-- Top Nav Tabs (RadioButton) -->
    <Style Selector="RadioButton.NavTab">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0,0,0,2"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="FontFamily" Value="Inter"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="0,0,0,8"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="{StaticResource FastTransition}"/>
                <BrushTransition Property="BorderBrush" Duration="{StaticResource FastTransition}"/>
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="RadioButton.NavTab:checked">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PriceUpBrush}"/>
    </Style>
    <Style Selector="RadioButton.NavTab:pointerover">
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- Timeframe Pill (RadioButton) -->
    <Style Selector="RadioButton.TimeframePill">
        <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Margin" Value="2,0"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontFamily" Value="Inter"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="{StaticResource FastTransition}"/>
                <BrushTransition Property="BorderBrush" Duration="{StaticResource FastTransition}"/>
                <BrushTransition Property="Background" Duration="{StaticResource FastTransition}"/>
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="RadioButton.TimeframePill:checked">
        <Setter Property="Foreground" Value="{StaticResource PriceUpBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource PriceUpBrush}"/>
        <Setter Property="Background" Value="#1A22C55E"/>
    </Style>

    <!-- Order Type Pill (RadioButton) -->
    <Style Selector="RadioButton.OrderTypePill">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderBrush" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="CornerRadius" Value="{StaticResource PillCornerRadius}"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="FontFamily" Value="Inter"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="{StaticResource FastTransition}"/>
                <BrushTransition Property="Background" Duration="{StaticResource FastTransition}"/>
                <BrushTransition Property="BorderBrush" Duration="{StaticResource FastTransition}"/>
            </Transitions>
        </Setter>
        <Setter Property="Template">
            <ControlTemplate>
                <Border Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                    <ContentPresenter Content="{TemplateBinding Content}"
                                      HorizontalAlignment="Center"
                                      VerticalAlignment="Center"/>
                </Border>
            </ControlTemplate>
        </Setter>
    </Style>
    <Style Selector="RadioButton.OrderTypePill:checked">
        <Setter Property="Background" Value="#2622C55E"/>
        <Setter Property="BorderBrush" Value="{StaticResource PriceUpBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource PriceUpBrush}"/>
    </Style>

    <!-- Flat Button -->
    <Style Selector="Button.Flat">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="Padding" Value="8,4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="{StaticResource FastTransition}"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="Button.Flat:pointerover /template/ ContentPresenter#PART_ContentPresenter">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>

    <!-- DataGrid overrides -->
    <Style Selector="DataGrid">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="RowBackground" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="HeadersVisibility" Value="Column"/>
    </Style>
    <Style Selector="DataGridColumnHeader">
        <Setter Property="Background" Value="{StaticResource SurfaceBrush}"/>
        <Setter Property="Foreground" Value="#52525B"/>
        <Setter Property="FontFamily" Value="Inter"/>
        <Setter Property="FontSize" Value="9"/>
        <Setter Property="FontWeight" Value="Bold"/>
        <Setter Property="SeparatorBrush" Value="{StaticResource PanelBorderBrush}"/>
    </Style>
    <Style Selector="DataGridCell">
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontFamily" Value="Inter"/>
    </Style>

    <!-- Expander Modernization -->
    <Style Selector="Expander">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Margin" Value="0,0,0,16"/>
    </Style>
    <Style Selector="Expander /template/ ToggleButton#ExpanderHeader">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Padding" Value="0,0,0,8"/>
    </Style>

    <!-- Phase 5 Animations -->
    <!-- Smooth value transitions -->
    <Style Selector="ProgressBar.Smooth">
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Value" Duration="0:0:1.0" Easing="LinearEasing"/>
            </Transitions>
        </Setter>
    </Style>

    <Style Selector="TextBlock.PriceFlash">
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Foreground" Duration="0:0:0.3"/>
            </Transitions>
        </Setter>
    </Style>

    <!-- Slide-in Animations using KeyFrames -->
    <Style Selector="Border.SlideIn1">
        <Style.Animations>
            <Animation Duration="0:0:0.4" Easing="CubicEaseOut">
                <KeyFrame Cue="0%">
                    <Setter Property="TranslateTransform.Y" Value="20"/>
                    <Setter Property="Opacity" Value="0"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="TranslateTransform.Y" Value="0"/>
                    <Setter Property="Opacity" Value="1"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Border.SlideIn2">
        <Style.Animations>
            <Animation Duration="0:0:0.5" Easing="CubicEaseOut" Delay="0:0:0.05">
                <KeyFrame Cue="0%">
                    <Setter Property="TranslateTransform.Y" Value="20"/>
                    <Setter Property="Opacity" Value="0"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="TranslateTransform.Y" Value="0"/>
                    <Setter Property="Opacity" Value="1"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Border.SlideIn3">
        <Style.Animations>
            <Animation Duration="0:0:0.6" Easing="CubicEaseOut" Delay="0:0:0.10">
                <KeyFrame Cue="0%">
                    <Setter Property="TranslateTransform.Y" Value="20"/>
                    <Setter Property="Opacity" Value="0"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="TranslateTransform.Y" Value="0"/>
                    <Setter Property="Opacity" Value="1"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Border.SlideIn4">
        <Style.Animations>
            <Animation Duration="0:0:0.7" Easing="CubicEaseOut" Delay="0:0:0.15">
                <KeyFrame Cue="0%">
                    <Setter Property="TranslateTransform.Y" Value="20"/>
                    <Setter Property="Opacity" Value="0"/>
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="TranslateTransform.Y" Value="0"/>
                    <Setter Property="Opacity" Value="1"/>
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <Style Selector="Grid:pointerover Border.HoverDetails">
        <Setter Property="Height" Value="30"/>
        <Setter Property="Opacity" Value="1"/>
    </Style>
    <Style Selector="Border.HoverDetails">
        <Setter Property="Transitions">
            <Transitions>
                <DoubleTransition Property="Height" Duration="0:0:0.2" Easing="CubicEaseOut"/>
                <DoubleTransition Property="Opacity" Duration="0:0:0.2" Easing="CubicEaseOut"/>
            </Transitions>
        </Setter>
    </Style>

    <!-- Ghost Mode Toggle -->
    <Style Selector="ToggleButton.GhostToggle">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush" Value="{StaticResource PanelBorderBrush}"/>
        <Setter Property="Padding" Value="12,6"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Transitions">
            <Transitions>
                <BrushTransition Property="Background" Duration="0:0:0.2"/>
                <BrushTransition Property="Foreground" Duration="0:0:0.2"/>
                <BrushTransition Property="BorderBrush" Duration="0:0:0.2"/>
                <TransformOperationsTransition Property="RenderTransform" Duration="0:0:0.2"/>
            </Transitions>
        </Setter>
    </Style>
    <Style Selector="ToggleButton.GhostToggle:pointerover">
        <Setter Property="Background" Value="{StaticResource Surface2Brush}"/>
    </Style>
    <Style Selector="ToggleButton.GhostToggle:checked">
        <Setter Property="Background" Value="#1AA855F7"/>
        <Setter Property="Foreground" Value="{StaticResource AccentPurpleBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource AccentPurpleBrush}"/>
    </Style>
</Styles>
